# App
NODE_ENV=development
PORT=3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Database
DATABASE_URL="postgresql://admin:secure_password_123@localhost:5432/clinic_db?schema=public"
DATABASE_URL_POOLED="postgresql://admin:secure_password_123@localhost:5432/clinic_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="your-refresh-token-secret"
REFRESH_TOKEN_EXPIRES_IN="30d"

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=clinic-documents

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid (Email)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@clinic.com

# Auth0 (Optional)
AUTH0_SECRET=
AUTH0_BASE_URL=
AUTH0_ISSUER_BASE_URL=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Telehealth
ZOOM_API_KEY=
ZOOM_API_SECRET=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=

# Monitoring
SENTRY_DSN=
DATADOG_API_KEY=