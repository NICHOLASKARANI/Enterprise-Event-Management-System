<!-- app/views/projects/show.html.erb -->
<div class="container-fluid mt-4">
  <div class="row">
    <div class="col-md-3">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title">Project Details</h5>
          <p><strong>Status:</strong> <%= @project.status %></p>
          <p><strong>Owner:</strong> <%= @project.owner.full_name %></p>
          <p><strong>Progress:</strong> <%= @project.progress %>%</p>
          <p><strong>Tasks:</strong> <%= @project.tasks.count %></p>
          <p><strong>Members:</strong> <%= @project.members.count %></p>
          
          <div class="mt-3">
            <%= link_to "Edit Project", edit_project_path(@project), class: "btn btn-sm btn-outline-primary" %>
            <%= button_to "Delete", @project, method: :delete, class: "btn btn-sm btn-outline-danger", data: { confirm: "Are you sure?" } %>
          </div>
        </div>
      </div>
    </div>
    
    <div class="col-md-9">
      <div class="mb-3">
        <h2>Kanban Board</h2>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newTaskModal">
          + New Task
        </button>
      </div>
      
      <div class="row">
        <% ["todo", "in_progress", "review", "done"].each do |status| %>
          <div class="col-md-3">
            <div class="card">
              <div class="card-header bg-light">
                <strong><%= status.humanize %></strong>
                <span class="badge bg-secondary float-end">
                  <%= @kanban_tasks[status]&.count || 0 %>
                </span>
              </div>
              <div class="card-body" style="min-height: 400px">
                <div class="task-list" data-status="<%= status %>">
                  <% (@kanban_tasks[status] || []).each do |task| %>
                    <div class="card mb-2 task-card" data-task-id="<%= task.id %>">
                      <div class="card-body p-2">
                        <h6 class="card-title"><%= task.title %></h6>
                        <p class="card-text small">
                          <span class="badge bg-<%= task.priority_badge_color %>">
                            <%= task.priority %>
                          </span>
                          <% if task.assignee %>
                            <small class="text-muted">to: <%= task.assignee.full_name %></small>
                          <% end %>
                        </p>
                        <div class="btn-group btn-group-sm" role="group">
                          <%= link_to "View", project_task_path(@project, task), class: "btn btn-outline-primary" %>
                          <%= link_to "Edit", edit_project_task_path(@project, task), class: "btn btn-outline-secondary" %>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Modal for new task -->
<div class="modal fade" id="newTaskModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Create New Task</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <%= form_with model: [@project, Task.new], local: true do |f| %>
        <div class="modal-body">
          <div class="mb-3">
            <%= f.label :title, class: "form-label" %>
            <%= f.text_field :title, class: "form-control", required: true %>
          </div>
          
          <div class="mb-3">
            <%= f.label :description, class: "form-label" %>
            <%= f.text_area :description, class: "form-control", rows: 3 %>
          </div>
          
          <div class="mb-3">
            <%= f.label :priority, class: "form-label" %>
            <%= f.select :priority, [["Low", "low"], ["Medium", "medium"], ["High", "high"], ["Urgent", "urgent"]], {}, class: "form-select" %>
          </div>
          
          <div class="mb-3">
            <%= f.label :due_date, class: "form-label" %>
            <%= f.date_field :due_date, class: "form-control" %>
          </div>
          
          <div class="mb-3">
            <%= f.label :assignee_id, "Assign to", class: "form-label" %>
            <%= f.select :assignee_id, @project.members.map { |m| [m.full_name, m.id] }, { include_blank: "Unassigned" }, class: "form-select" %>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <%= f.submit "Create Task", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>